{
  "version": 8,
  "name": "Atreides Crisis Map",
  "sprite": "mapbox://sprites/mapbox/dark-v11",
  "glyphs": "mapbox://fonts/mapbox/{fontstack}/{range}.pbf",
  "projection": {
    "name": "globe"
  },
  "fog": {
    "range": [1, 12],
    "color": "#0C0A16",
    "high-color": "#1A1030",
    "horizon-blend": 0.08,
    "space-color": "#06040D",
    "star-intensity": 0.6
  },
  "sources": {
    "mapbox-streets": {
      "type": "vector",
      "url": "mapbox://mapbox.mapbox-streets-v8"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#0C0A16"
      }
    },
    {
      "id": "sky",
      "type": "sky",
      "paint": {
        "sky-type": "atmosphere",
        "sky-atmosphere-sun": [0, 0],
        "sky-atmosphere-sun-intensity": 15,
        "sky-atmosphere-color": "#1A1030"
      }
    },
    {
      "id": "landuse-commercial",
      "type": "fill",
      "source": "mapbox-streets",
      "source-layer": "landuse",
      "filter": ["==", "class", "commercial_area"],
      "paint": {
        "fill-color": "#110E1F",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "landuse-industrial",
      "type": "fill",
      "source": "mapbox-streets",
      "source-layer": "landuse",
      "filter": ["==", "class", "industrial"],
      "paint": {
        "fill-color": "#0F0D1A",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "landuse-park",
      "type": "fill",
      "source": "mapbox-streets",
      "source-layer": "landuse",
      "filter": ["==", "class", "park"],
      "paint": {
        "fill-color": "#0E1219",
        "fill-opacity": 0.7
      }
    },
    {
      "id": "landuse-cemetery",
      "type": "fill",
      "source": "mapbox-streets",
      "source-layer": "landuse",
      "filter": ["==", "class", "cemetery"],
      "paint": {
        "fill-color": "#0E1118",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "landuse-hospital",
      "type": "fill",
      "source": "mapbox-streets",
      "source-layer": "landuse",
      "filter": ["==", "class", "hospital"],
      "paint": {
        "fill-color": "#14101E",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "landuse-school",
      "type": "fill",
      "source": "mapbox-streets",
      "source-layer": "landuse",
      "filter": ["==", "class", "school"],
      "paint": {
        "fill-color": "#13101D",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "mapbox-streets",
      "source-layer": "water",
      "paint": {
        "fill-color": "#0A0E1F",
        "fill-opacity": 1
      }
    },
    {
      "id": "water-pattern",
      "type": "fill",
      "source": "mapbox-streets",
      "source-layer": "water",
      "paint": {
        "fill-color": "#0D1228",
        "fill-opacity": 0.3
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#0D1228",
        "line-width": ["interpolate", ["linear"], ["zoom"], 6, 0.5, 14, 3],
        "line-opacity": 0.8
      }
    },
    {
      "id": "building",
      "type": "fill",
      "source": "mapbox-streets",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "fill-color": "#141020",
        "fill-opacity": ["interpolate", ["linear"], ["zoom"], 13, 0, 15, 0.7]
      }
    },
    {
      "id": "building-outline",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "building",
      "minzoom": 13,
      "paint": {
        "line-color": "#1C1730",
        "line-width": 0.5,
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 13, 0, 15, 0.5]
      }
    },
    {
      "id": "admin-boundary-country",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "admin",
      "filter": ["all", ["==", "admin_level", 2], ["==", "maritime", 0]],
      "paint": {
        "line-color": "#2A1F3D",
        "line-width": ["interpolate", ["linear"], ["zoom"], 2, 0.8, 8, 2],
        "line-dasharray": [3, 2]
      }
    },
    {
      "id": "admin-boundary-state",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "admin",
      "filter": ["all", ["==", "admin_level", 4], ["==", "maritime", 0]],
      "minzoom": 3,
      "paint": {
        "line-color": "#1F1830",
        "line-width": ["interpolate", ["linear"], ["zoom"], 3, 0.3, 8, 1],
        "line-dasharray": [2, 2],
        "line-opacity": 0.6
      }
    },
    {
      "id": "tunnel-minor",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["all", ["==", "structure", "tunnel"], ["any", ["==", "class", "street"], ["==", "class", "street_limited"], ["==", "class", "service"]]],
      "paint": {
        "line-color": "#1A1528",
        "line-width": ["interpolate", ["exponential", 1.5], ["zoom"], 12, 0.5, 18, 6],
        "line-dasharray": [3, 3],
        "line-opacity": 0.5
      }
    },
    {
      "id": "tunnel-major",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["all", ["==", "structure", "tunnel"], ["any", ["==", "class", "primary"], ["==", "class", "secondary"], ["==", "class", "tertiary"]]],
      "paint": {
        "line-color": "#201A30",
        "line-width": ["interpolate", ["exponential", 1.5], ["zoom"], 10, 1, 18, 10],
        "line-dasharray": [3, 3],
        "line-opacity": 0.5
      }
    },
    {
      "id": "road-path",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["all", ["!=", "structure", "tunnel"], ["==", "class", "path"]],
      "paint": {
        "line-color": "#1A1528",
        "line-width": ["interpolate", ["exponential", 1.5], ["zoom"], 14, 0.5, 18, 2],
        "line-dasharray": [4, 2],
        "line-opacity": 0.4
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["all", ["!=", "structure", "tunnel"], ["any", ["==", "class", "street"], ["==", "class", "street_limited"], ["==", "class", "service"]]],
      "minzoom": 12,
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#1E1830",
        "line-width": ["interpolate", ["exponential", 1.5], ["zoom"], 12, 0.5, 18, 8],
        "line-opacity": ["interpolate", ["linear"], ["zoom"], 12, 0, 14, 0.7]
      }
    },
    {
      "id": "road-tertiary",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["all", ["!=", "structure", "tunnel"], ["==", "class", "tertiary"]],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#221C35",
        "line-width": ["interpolate", ["exponential", 1.5], ["zoom"], 10, 0.5, 18, 10]
      }
    },
    {
      "id": "road-secondary",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["all", ["!=", "structure", "tunnel"], ["==", "class", "secondary"]],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#271F3A",
        "line-width": ["interpolate", ["exponential", 1.5], ["zoom"], 8, 0.5, 18, 14]
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["all", ["!=", "structure", "tunnel"], ["==", "class", "primary"]],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#2D2342",
        "line-width": ["interpolate", ["exponential", 1.5], ["zoom"], 6, 0.5, 18, 18]
      }
    },
    {
      "id": "road-trunk",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["all", ["!=", "structure", "tunnel"], ["==", "class", "trunk"]],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#33274A",
        "line-width": ["interpolate", ["exponential", 1.5], ["zoom"], 5, 0.5, 18, 20]
      }
    },
    {
      "id": "road-motorway",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["all", ["!=", "structure", "tunnel"], ["==", "class", "motorway"]],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#3D2B55",
        "line-width": ["interpolate", ["exponential", 1.5], ["zoom"], 5, 0.8, 18, 24]
      }
    },
    {
      "id": "bridge-minor",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["all", ["==", "structure", "bridge"], ["any", ["==", "class", "street"], ["==", "class", "street_limited"], ["==", "class", "service"]]],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#231D38",
        "line-width": ["interpolate", ["exponential", 1.5], ["zoom"], 12, 0.5, 18, 8]
      }
    },
    {
      "id": "bridge-major",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["all", ["==", "structure", "bridge"], ["any", ["==", "class", "primary"], ["==", "class", "secondary"], ["==", "class", "tertiary"], ["==", "class", "trunk"], ["==", "class", "motorway"]]],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "#33274A",
        "line-width": ["interpolate", ["exponential", 1.5], ["zoom"], 6, 0.5, 18, 20]
      }
    },
    {
      "id": "rail",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["==", "class", "major_rail"],
      "paint": {
        "line-color": "#1F1830",
        "line-width": ["interpolate", ["linear"], ["zoom"], 8, 0.5, 14, 1.5],
        "line-dasharray": [4, 4],
        "line-opacity": 0.5
      }
    },
    {
      "id": "aeroway-runway",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "aeroway",
      "filter": ["==", "type", "runway"],
      "paint": {
        "line-color": "#2A2040",
        "line-width": ["interpolate", ["exponential", 1.5], ["zoom"], 10, 1, 18, 30]
      }
    },
    {
      "id": "aeroway-taxiway",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "aeroway",
      "filter": ["==", "type", "taxiway"],
      "paint": {
        "line-color": "#221A35",
        "line-width": ["interpolate", ["exponential", 1.5], ["zoom"], 10, 0.5, 18, 10]
      }
    },
    {
      "id": "country-label",
      "type": "symbol",
      "source": "mapbox-streets",
      "source-layer": "place_label",
      "filter": ["==", "class", "country"],
      "layout": {
        "text-field": "{name_en}",
        "text-font": ["DIN Offc Pro Medium", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 2, 10, 6, 16],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.1,
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#8B7BA8",
        "text-halo-color": "#0C0A16",
        "text-halo-width": 1.5,
        "text-opacity": ["interpolate", ["linear"], ["zoom"], 2, 0.8, 8, 1]
      }
    },
    {
      "id": "state-label",
      "type": "symbol",
      "source": "mapbox-streets",
      "source-layer": "place_label",
      "filter": ["==", "class", "state"],
      "minzoom": 4,
      "layout": {
        "text-field": "{name_en}",
        "text-font": ["DIN Offc Pro Regular", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 4, 8, 8, 13],
        "text-transform": "uppercase",
        "text-letter-spacing": 0.15,
        "text-max-width": 7
      },
      "paint": {
        "text-color": "#6B5F85",
        "text-halo-color": "#0C0A16",
        "text-halo-width": 1,
        "text-opacity": 0.8
      }
    },
    {
      "id": "city-label-major",
      "type": "symbol",
      "source": "mapbox-streets",
      "source-layer": "place_label",
      "filter": ["all", ["==", "class", "settlement"], [">=", "symbolrank", 1], ["<=", "symbolrank", 4]],
      "layout": {
        "text-field": "{name_en}",
        "text-font": ["DIN Offc Pro Medium", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 4, 10, 12, 18],
        "text-max-width": 8
      },
      "paint": {
        "text-color": "#C4B5DB",
        "text-halo-color": "#0C0A16",
        "text-halo-width": 1.5
      }
    },
    {
      "id": "city-label-minor",
      "type": "symbol",
      "source": "mapbox-streets",
      "source-layer": "place_label",
      "filter": ["all", ["==", "class", "settlement"], [">=", "symbolrank", 5]],
      "minzoom": 6,
      "layout": {
        "text-field": "{name_en}",
        "text-font": ["DIN Offc Pro Regular", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 6, 8, 14, 14],
        "text-max-width": 7
      },
      "paint": {
        "text-color": "#9A8CB5",
        "text-halo-color": "#0C0A16",
        "text-halo-width": 1
      }
    },
    {
      "id": "poi-label",
      "type": "symbol",
      "source": "mapbox-streets",
      "source-layer": "poi_label",
      "minzoom": 14,
      "layout": {
        "text-field": "{name_en}",
        "text-font": ["DIN Offc Pro Regular", "Arial Unicode MS Regular"],
        "text-size": 11,
        "text-max-width": 7,
        "text-offset": [0, 0.8],
        "text-anchor": "top"
      },
      "paint": {
        "text-color": "#6B5F85",
        "text-halo-color": "#0C0A16",
        "text-halo-width": 1,
        "text-opacity": 0.7
      }
    },
    {
      "id": "road-label",
      "type": "symbol",
      "source": "mapbox-streets",
      "source-layer": "road",
      "minzoom": 12,
      "filter": ["any", ["==", "class", "primary"], ["==", "class", "secondary"], ["==", "class", "tertiary"], ["==", "class", "trunk"], ["==", "class", "motorway"]],
      "layout": {
        "text-field": "{name_en}",
        "text-font": ["DIN Offc Pro Regular", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 12, 9, 18, 13],
        "symbol-placement": "line",
        "text-max-angle": 30,
        "text-rotation-alignment": "map",
        "text-pitch-alignment": "viewport"
      },
      "paint": {
        "text-color": "#7A6B99",
        "text-halo-color": "#0C0A16",
        "text-halo-width": 1.2,
        "text-opacity": 0.8
      }
    },
    {
      "id": "water-label",
      "type": "symbol",
      "source": "mapbox-streets",
      "source-layer": "natural_label",
      "filter": ["==", "class", "water"],
      "layout": {
        "text-field": "{name_en}",
        "text-font": ["DIN Offc Pro Italic", "Arial Unicode MS Regular"],
        "text-size": ["interpolate", ["linear"], ["zoom"], 6, 10, 14, 16],
        "text-max-width": 7,
        "text-letter-spacing": 0.1
      },
      "paint": {
        "text-color": "#3D4670",
        "text-halo-color": "#0A0E1F",
        "text-halo-width": 1
      }
    }
  ]
}
